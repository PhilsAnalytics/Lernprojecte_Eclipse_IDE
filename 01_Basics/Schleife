public class Schleife {

	public static void main(String[] args) {
		
		// For- Schleife
		
		for (int i = 0; i < 6; i = i + 1) 
		{
			if (i < 5) 
			{
				System.out.println("Ich trinke ein Bier!");
			} 
			else 
			{
				System.out.println("Ich trinke kein Bier mehr!");
			}
		}
	}
}

