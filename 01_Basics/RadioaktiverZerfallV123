public class RadioaktiverZerfallV2 {
	/*
	 * Aufgaben: 2. Führen Sie eine "Zwischenvariante" ein, die prüft, ob nicht der
	 * Sonderfall gegeben ist, dass schon zu Beginn der Startwert unter dem
	 * Grenzwert liegt. In einem solchen Fall wäre die Ausgabe "unschön": Die
	 * Fragestellung bliebe gleich, die Rechnung bliebe leer u. als Antwort würde
	 * gesagt, es dauere Null Halbwertszeiten. Um das zu verhindern, prüfen Sie vor
	 * Betreten der Schleife mit einer zweiseitigen bed. Anw., ob der Sonderfall
	 * gegeben ist. Falls ja, soll weder die Berechnung noch die Antwort für den
	 * regulären Fall ausgegeben werden, sondern stattdessen eine entsprechende
	 * Meldung: "Schon zu Beginn liegt der Startwert unter dem Grenzwert".
	 */
  
	public static void main(String[] args) {

		double startWert = 1.0;
		double grenzWert = 0.1;

		System.out.println("Frage: Wie viele Halbwertszeiten vergehen,\nbis die Menge unter " + grenzWert + " sinkt?\n");

		if (startWert < grenzWert) {

			System.out.println("Schon zu Beginn liegt der Startwert unter dem Grenzwert.");
		} else {

			double aktuWert = startWert;
			int hwz = 0;

			while (aktuWert >= grenzWert) {

				aktuWert /= 2.0;
				hwz++;
				System.out.println("Nach " + hwz + " HWZ: " + aktuWert);
			}
			System.out.println("\nAntwort: Nach " + hwz + " HWZ(s) sinkt die Menge \nerstmals unter den Grenzwert.");
		}
	}
}

