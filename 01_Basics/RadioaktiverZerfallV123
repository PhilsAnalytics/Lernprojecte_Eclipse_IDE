/*
	 * Berechnen Sie das mit einer while-Schleife. Benutzen Sie die Variablen: -
	 * startWert - grenzWert - aktuWert - hwz "startWert" u. "grenzWert" sollen als
	 * double-Variablen für den Benutzer zugänglich sein, nicht hingegen "aktuWert"
	 * als double sowie "hwz" als int. Formulieren Sie einen Frage- u. einen
	 * Antwortsatz! Aufgaben: 1. Implementieren Sie mit einer while-Schleife!
	 */

	public static void main(String[] args) {

		double startWert = 1.0;
		double grenzWert = 0.1;
		double aktuWert = startWert;
		int hwz = 0;

		System.out
				.println("Frage: Wie viele Halbwertszeiten vergehen,\nbis die Menge unter " + grenzWert + " sinkt?\n");

		while (aktuWert >= grenzWert) {

			aktuWert /= 2.0;
			hwz++;
			System.out.println("Nach " + hwz + " HWZ: " + aktuWert);
		}
		System.out.println("\nAntwort: Nach " + hwz + " HWZ(s) sinkt die Menge \nerstmals unter den Grenzwert.");
	}
}

