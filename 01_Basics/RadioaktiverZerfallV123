public class RadioaktiverZerfallV3 {
	/*
	 * Aufgaben: 3. Prüfen Sie, ob hier ein Umwandlung in eine do-while-Schleife
	 * sinnvoll ist. Falls ja, wandeln Sie um u. überzeugen Sie sich davon, dass das
	 * Ergebnis gleich bleibt. Was ist der Vorteil der dritten Version?
	 */

	public static void main(String[] args) {

		double startWert = 1.0;
		double grenzWert = 0.1;

		System.out
				.println("Frage: Wie viele Halbwertszeiten vergehen, \nbis die Menge unter " + grenzWert + " sinkt?\n");

		if (startWert < grenzWert) {

			System.out.println("Schon zu Beginn liegt der Startwert unter dem Grenzwert.");

		} else {
			double aktuWert = startWert;
			int hwz = 0;

			do {
				aktuWert /= 2.0;
				hwz++;
				System.out.println("Nach " + hwz + " HWZ: " + aktuWert);
			} while (aktuWert >= grenzWert);

			System.out.println("\nAntwort: Nach " + hwz + " HWZ(s) sinkt die Menge \nerstmals unter den Grenzwert.");
		}
	}
}
